<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/metadata">
    <apiVersion>59.0</apiVersion>
    <description>Scheduled flow that identifies batches nearing expiry (within 30 days) and creates notification tasks for the product manager.</description>
    <interviewLabel>Batch Expiry Notification {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Batch Expiry Notification</label>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <scheduledPaths>
            <name>Daily_Check</name>
            <label>Daily Expiry Check</label>
            <connector>
                <targetReference>Get_Expiring_Batches</targetReference>
            </connector>
            <maxBatchSize>200</maxBatchSize>
            <offsetNumber>0</offsetNumber>
            <offsetUnit>Hours</offsetUnit>
            <recordField>CreatedDate</recordField>
            <timeSource>RecordField</timeSource>
        </scheduledPaths>
    </start>
    <recordLookups>
        <name>Get_Expiring_Batches</name>
        <label>Get Expiring Batches</label>
        <object>Batch_Master__c</object>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Expiry_Date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>ThirtyDaysFromNow</elementReference>
            </value>
        </filters>
        <filters>
            <field>Expiry_Date__c</field>
            <operator>GreaterThan</operator>
            <value>
                <elementReference>Today</elementReference>
            </value>
        </filters>
        <filters>
            <field>Status__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Active</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <formulas>
        <name>ThirtyDaysFromNow</name>
        <dataType>Date</dataType>
        <expression>TODAY() + 30</expression>
    </formulas>
    <formulas>
        <name>Today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>
    <status>Draft</status>
</Flow>
