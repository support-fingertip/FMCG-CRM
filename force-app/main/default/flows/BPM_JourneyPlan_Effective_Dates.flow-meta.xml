<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <description>Auto-calculates Effective From and Effective To dates for Journey Plans based on the Month and Year fields when not explicitly set.</description>
    <environments>Default</environments>
    <formulas>
        <name>MonthNumber</name>
        <dataType>Number</dataType>
        <expression>CASE({!$Record.Month__c},
            "January", 1,
            "February", 2,
            "March", 3,
            "April", 4,
            "May", 5,
            "June", 6,
            "July", 7,
            "August", 8,
            "September", 9,
            "October", 10,
            "November", 11,
            "December", 12,
            1)</expression>
        <scale>0</scale>
    </formulas>
    <formulas>
        <name>EffectiveFromDate</name>
        <dataType>Date</dataType>
        <expression>DATE(VALUE({!$Record.Year__c}), {!MonthNumber}, 1)</expression>
    </formulas>
    <formulas>
        <name>EffectiveToDate</name>
        <dataType>Date</dataType>
        <expression>DATE(VALUE({!$Record.Year__c}), {!MonthNumber} + 1, 1) - 1</expression>
    </formulas>
    <interviewLabel>BPM Journey Plan Effective Dates {!$Flow.CurrentDateTime}</interviewLabel>
    <label>BPM Journey Plan Effective Dates</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <recordUpdates>
        <name>Set_Effective_Dates</name>
        <label>Set Effective Dates</label>
        <locationX>176</locationX>
        <locationY>335</locationY>
        <inputAssignments>
            <field>Effective_From__c</field>
            <value>
                <elementReference>EffectiveFromDate</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Effective_To__c</field>
            <value>
                <elementReference>EffectiveToDate</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_Effective_Dates</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Effective_From__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Month__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Year__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Journey_Plan__c</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
