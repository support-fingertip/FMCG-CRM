<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>No_Edit_After_Approval</fullName>
    <active>true</active>
    <errorConditionFormula>AND(ISCHANGED(Total_Planned_Visits__c), OR(ISPICKVAL(PRIORVALUE(Status__c), &apos;Approved&apos;), ISPICKVAL(PRIORVALUE(Status__c), &apos;Active&apos;)))</errorConditionFormula>
    <errorMessage>Cannot modify an approved or active Journey Plan. Please create a new plan or request revision.</errorMessage>
</ValidationRule>
