<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/metadata">
    <fullName>End_Time_After_Start</fullName>
    <active>true</active>
    <description>End time must be after start time</description>
    <errorConditionFormula>AND(NOT(ISBLANK(End_Time__c)), NOT(ISBLANK(Start_Time__c)), End_Time__c &lt; Start_Time__c)</errorConditionFormula>
    <errorDisplayField>End_Time__c</errorDisplayField>
    <errorMessage>End Time must be after Start Time.</errorMessage>
</ValidationRule>
