# --- Salesforce Connected App ---
# Use https://login.salesforce.com for production orgs,
# https://test.salesforce.com for sandboxes,
# or your My Domain URL (e.g. https://yourcompany.my.salesforce.com).
SF_LOGIN_URL=https://login.salesforce.com
SF_CLIENT_ID=your_connected_app_consumer_key_here
SF_CLIENT_SECRET=your_connected_app_consumer_secret_here

# --- App JWT settings ---
# Use a random string >= 32 bytes. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=1h

# --- Server ---
PORT=3000
CORS_ORIGIN=*
